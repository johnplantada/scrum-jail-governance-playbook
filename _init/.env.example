# Copy to .env and fill in. NEVER commit .env (add it to .gitignore).
# Secrets live here, never in chat — the bus carries coordination, not credentials.

# Mattermost (the message bus)
MATTERMOST_URL=http://localhost:8065
MATTERMOST_TEAM=__ORG__
MATTERMOST_TOKEN=                 # shared bot token (fallback identity)

# Per-agent bot tokens, so each agent is a distinct user (makes self/loop detection robust).
# One per department in org-chart.yaml. Name: MATTERMOST_TOKEN_<UPPERCASE_NAME>.
MATTERMOST_TOKEN_CEO=
MATTERMOST_TOKEN_BUSINESS=
MATTERMOST_TOKEN_IT=
MATTERMOST_TOKEN_CHAIRMAN=        # the Chairman's personal token (for the voice console)

# Agent LLM
ANTHROPIC_API_KEY=

# Runtime
ORG_CHART_PATH=./org-chart.yaml
AGENTS_DIR=./agents
PRODUCT_REPO=                     # local path to the product repo IT builds/PRs into
PRODUCT_GH_REPO=                  # owner/repo of the product (for scripts/last-ship.sh, deploy-watch)

# Optional: a local model for zero-token bulk offload (e.g. ollama llama3.1:8b)
OFFLOAD_LOCAL_MODEL=llama3.1:8b

# Behavior toggles
TRIAGE_MODE=enforce               # shadow = log only; enforce = act on the broadcast reply pre-gate
