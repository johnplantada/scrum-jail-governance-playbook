#!/usr/bin/env bash
#
# pre-push — the zero-spend CI gate (FIELD-NOTES §13; patterns.md Pattern 17).
#
# Mirrors .github/workflows/ci.yml job-for-job on the operator's machine, at push
# time, where compute is free — hosted Actions stay for rare deliberate runs (the
# workflow_dispatch-only deploy gate). Wire it once with `make install-hooks`
# (core.hooksPath = scripts/hooks): linked worktrees share repo config, so the
# org-worktree.sh PR worktrees and the runtime checkout all run the same hooks.
#
# SKIP_CI_HOOK=1 git push is the deliberate override — never a secret escape hatch.
set -u

if [ "${SKIP_CI_HOOK:-0}" = "1" ]; then
  echo "pre-push: SKIP_CI_HOOK=1 — suite skipped (deliberate override)"
  exit 0
fi
cd "$(git rev-parse --show-toplevel)" || exit 1

fail() {
  echo
  echo "pre-push: REFUSED — $1 failed."
  echo "pre-push: fix it, or override deliberately with: SKIP_CI_HOOK=1 git push"
  exit 1
}

# ── ci.yml job `test`: python syntax + every unit test ──────────────────────
python3 -m py_compile scripts/*.py || fail "python syntax (py_compile)"
for t in scripts/test_*.py; do
  PYTHONPATH=scripts python3 "$t" || fail "unit test $t"
done

# ── ci.yml job `lint`: shellcheck + the three linters ───────────────────────
if command -v shellcheck >/dev/null 2>&1; then
  shellcheck -S error scripts/*.sh scripts/hooks/pre-commit scripts/hooks/pre-push \
    || fail "shellcheck"
else
  echo "pre-push: shellcheck not installed — skipping (install it to mirror CI fully)"
fi
python3 scripts/lint_constitution.py || fail "constitution lint"
python3 scripts/blockers.py lint || fail "blocker-runbook lint"
python3 scripts/decisions.py check || fail "decisions-ledger check"

# ── ci.yml job `playbook drift`, against the LOCAL golden at the pinned commit ──
# A cheap --shared clone checked out at the pin, then the same `make check-playbook`
# CI runs. Warn-and-skip whenever it can't be judged (no pin, no local golden, pin
# not fetched yet): a stale local golden must not block a push it can't evaluate.
GOLDEN_REPO="${GOLDEN_REPO:-$HOME/codebase/scrum-jail-governance-playbook}"
pin=$(sed -n 's/^Source: scrum-jail-governance-playbook @ //p' playbook/SOURCE.md 2>/dev/null)
if [ -z "$pin" ] || [ ! -e "$GOLDEN_REPO/.git" ]; then
  echo "pre-push: playbook drift not evaluable (pin: ${pin:-none}; golden: $GOLDEN_REPO) — skipping"
else
  tmp=$(mktemp -d) || fail "mktemp for the drift clone"
  trap 'rm -rf "$tmp"' EXIT
  if git clone --quiet --shared "$GOLDEN_REPO" "$tmp/golden" 2>/dev/null \
     && git -C "$tmp/golden" checkout --quiet --detach "$pin" 2>/dev/null; then
    make check-playbook GOLDEN_REPO="$tmp/golden" \
      || fail "playbook drift (edits belong in the golden, then: make sync-playbook)"
  else
    echo "pre-push: pin $pin not present in the local golden — skipping drift check"
  fi
fi

echo "pre-push: suite green — pushing"
