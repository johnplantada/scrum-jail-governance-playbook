#!/usr/bin/env bash
# pre-push — run the CI suite locally before any push (zero-spend Actions strategy,
# docs/actions-budget.md). Hosted workflows are disabled on GitHub; this hook is the
# merge gate now, so it mirrors .github/workflows/ci.yml job-for-job. If you change a
# check there, change it here (and vice versa).
#
# Escape hatch for a deliberate unchecked push:  SKIP_CI_HOOK=1 git push …
set -uo pipefail
[ -n "${SKIP_CI_HOOK:-}" ] && { echo "pre-push: SKIP_CI_HOOK set — skipping CI suite" >&2; exit 0; }
cd "$(git rev-parse --show-toplevel)"
# git exports GIT_DIR (absolute, per-worktree) to hooks; it would override git -C in
# the golden-clone drift check below and silently warn-skip it on every worktree push.
unset GIT_DIR GIT_WORK_TREE

fail=0
section() { printf '\n── %s ──\n' "$1"; }

# ── job: test ────────────────────────────────────────────────────────────────
section "test: python syntax"
python3 -m py_compile scripts/*.py || fail=1

section "test: unit tests"
for t in scripts/test_*.py; do
  echo "→ $t"
  PYTHONPATH=scripts python3 "$t" || fail=1
done

# ── job: lint ────────────────────────────────────────────────────────────────
section "lint: shellcheck (severity=error)"
if command -v shellcheck >/dev/null 2>&1; then
  shellcheck --severity=error scripts/*.sh scripts/hooks/* || fail=1
else
  echo "⚠ shellcheck not installed (brew install shellcheck) — skipping; CI parity is incomplete" >&2
fi

section "lint: constitution / blockers / decisions"
python3 scripts/lint_constitution.py || fail=1
python3 scripts/blockers.py lint || fail=1
python3 scripts/decisions.py check || fail=1

# ── job: playbook drift ──────────────────────────────────────────────────────
# CI clones the golden at the pin from playbook/SOURCE.md. Locally we do the same via a
# cheap shared clone of the local golden checkout; if the pin isn't present there
# (stale local golden), warn and skip rather than block the push on an unevaluable check.
section "playbook drift"
golden_src="${GOLDEN_REPO:-$HOME/codebase/scrum-jail-governance-playbook}"
pin="$(sed -n 's/^Source: scrum-jail-governance-playbook @ //p' playbook/SOURCE.md)"
if [ -z "$pin" ]; then
  echo "DRIFT: no pinned commit in playbook/SOURCE.md" >&2; fail=1
elif [ ! -d "$golden_src" ]; then
  echo "⚠ golden checkout not found ($golden_src) — skipping drift check" >&2
else
  tmp="$(mktemp -d)"
  if git clone -q --shared --no-checkout "$golden_src" "$tmp/golden" \
     && git -C "$tmp/golden" checkout -q --detach "$pin" 2>/dev/null; then
    make check-playbook GOLDEN_REPO="$tmp/golden" || fail=1
  else
    echo "⚠ pin $pin not in local golden ($golden_src) — git -C $golden_src fetch, then retry; skipping" >&2
  fi
  rm -rf "$tmp"
fi

echo
if [ "$fail" != 0 ]; then
  echo "✋ pre-push: CI suite FAILED — push refused (SKIP_CI_HOOK=1 to override deliberately)" >&2
  exit 1
fi
echo "✓ pre-push: CI suite green"
exit 0
