#!/usr/bin/env python3
"""orggen — stamp a new governance-gated multi-agent org from this golden playbook.

Mirrors the lambdagen/spagen golden-example generators: the pattern lives here, and orggen
copies + parameterizes it into a fresh org repo. It stamps the GOVERNANCE + BEHAVIORAL layer
(org-chart, constitution, agent mandates, blocker + env seeds, the playbook docs). The
RUNTIME — the Python/gh scripts the constitution names (runner.py + wake-rules.yaml,
agent-run.sh, pm-gh.sh, workitems.py, blockers.py, spend_log.py, decisions.py, last-ship.sh,
github-pm-setup.sh, the .claude/skills) — is a separate dependency living in the reference
org repo; orggen prints how to bring it in.

  orggen init <target-dir> [--org NAME] [--product NAME] [--goal GOAL]
              [--chairman-github USERNAME] [--product-repo OWNER/REPO]
              [--departments ceo,business,it]

Example:
  bin/orggen init ../acme-org --product "acme.com" --chairman-github yourhandle \\
      --product-repo yourhandle/acme
"""
import argparse
import os
import sys

REPO = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
INIT = os.path.join(REPO, "_init")

# Docs copied verbatim into the new org (the playbook it keeps next to its config).
VERBATIM_DOCS = ["patterns.md", "safe.md", "blocker-ledger.md", "emoji-gate.md",
                 "envelopes.yaml", "FIELD-NOTES.md", "RUNBOOK.md"]

# (name, role, reports_to). The CEO reports to the board; the rest to the CEO.
DEFAULT_DEPARTMENTS = [
    ("ceo", "chief-executive", "board"),
    ("business", "demand", "ceo"),
    ("it", "supply", "ceo"),
]


def read(path):
    with open(path, encoding="utf-8") as f:
        return f.read()


def write(path, text):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w", encoding="utf-8") as f:
        f.write(text)


def fill(text, **kv):
    for k, v in kv.items():
        text = text.replace("{{" + k + "}}", v).replace("__" + k + "__", v)
    return text


def departments(spec):
    if not spec:
        return DEFAULT_DEPARTMENTS
    out = []
    for name in [s.strip() for s in spec.split(",") if s.strip()]:
        if name == "ceo":
            out.append(("ceo", "chief-executive", "board"))
        else:
            out.append((name, name, "ceo"))
    if not any(d[0] == "ceo" for d in out):
        out.insert(0, DEFAULT_DEPARTMENTS[0])
    return out


def dept_block(name, role, reports_to):
    """One org-chart departments: entry, generated from the same tuple that stamps the agent
    mandate — so the chart and agents/ can never disagree about who exists."""
    is_ceo = name == "ceo"
    max_sub = 0 if is_ceo else 4
    budget = 300000 if is_ceo else 500000
    sub_note = ("CEO escalates; it doesn't spawn sub-teams itself" if is_ceo
                else "May spawn sub-teams within this cap")
    return (
        f"  # ── {name.upper()} ────────────────────────────────\n"
        f"  - name: {name}\n"
        f"    role: {role}\n"
        f"    reports_to: {reports_to}\n"
        f"    model: sonnet                 # default tier; a sustained raise is a 💎 decisions.yaml PR\n"
        f"    envelope:\n"
        f"      max_subagents: {max_sub}            # {sub_note}\n"
        f"      daily_token_budget: {budget}\n"
        f"      can_spend: false\n"
        f"      can_deploy: false\n"
        f"    teams: []\n"
    )


def cmd_init(args):
    target = os.path.abspath(args.target)
    if os.path.exists(target) and os.listdir(target):
        sys.exit(f"orggen: target '{target}' exists and is not empty — refusing to overwrite.")
    org = args.org or os.path.basename(target.rstrip("/"))
    product = args.product or org
    goal = args.goal or "<YOUR GOAL — e.g. $10k/month>"
    chairman = args.chairman_github or "<YOUR_GITHUB_USERNAME>"
    org_gh_repo = f"{chairman}/{org}"
    product_gh_repo = args.product_repo or f"{chairman}/<product-repo>"
    depts = departments(args.departments)

    # 1. Verbatim playbook docs.
    for doc in VERBATIM_DOCS:
        src = os.path.join(REPO, doc)
        if os.path.exists(src):
            write(os.path.join(target, doc), read(src))

    # 2. org-chart.yaml — from the _init template; the departments: block is generated from the
    #    SAME dept list that stamps the agent mandates (below), so the chart and agents/ can never
    #    disagree about who exists.
    dept_blocks = "\n".join(dept_block(*d) for d in depts)
    chart = fill(read(os.path.join(INIT, "org-chart.yaml")),
                 PRODUCT=product, CHAIRMAN_GITHUB=chairman, DEPARTMENTS=dept_blocks,
                 REVIEW_INTERVAL="20", PI_INTERVAL="3", UNLOCK_WIP_LIMIT="5")
    write(os.path.join(target, "org-chart.yaml"), chart)

    # 3. Constitution + ledger + env (substituted from _init/).
    write(os.path.join(target, "DESIGN.md"), fill(read(os.path.join(INIT, "DESIGN.md")), PRODUCT=product, GOAL=goal))
    write(os.path.join(target, "blockers.yaml"), read(os.path.join(INIT, "blockers.yaml")))
    write(os.path.join(target, ".env.example"),
          fill(read(os.path.join(INIT, ".env.example")),
               ORG_GH_REPO=org_gh_repo, PRODUCT_GH_REPO=product_gh_repo))

    # 4. Agents: the shared policy, the reusable template (product filled, names left as
    #    placeholders), and one stamped mandate per department.
    write(os.path.join(target, "agents", "_policy.md"), read(os.path.join(INIT, "agents", "_policy.md")))
    tmpl = read(os.path.join(INIT, "agents", "department.tmpl.md"))
    write(os.path.join(target, "agents", "department.tmpl.md"), fill(tmpl, PRODUCT=product))
    for name, role, reports_to in depts:
        mandate = fill(tmpl, NAME=name, ROLE=role, REPORTS_TO=reports_to, PRODUCT=product)
        write(os.path.join(target, "agents", f"{name}.md"), mandate)

    # 5. A short README for the new org.
    write(os.path.join(target, "README.md"), org_readme(org, product, depts))

    print(f"✓ stamped {org} → {target}")
    print(f"  product: {product}   chairman: {chairman}   departments: {', '.join(d[0] for d in depts)}")
    print(f"  org repo: {org_gh_repo}   product repo: {product_gh_repo}")
    print("\nNext steps (RUNBOOK.md walks through each one):")
    print("  1. Bring the RUNTIME — orggen stamps the governance layer only. The Python/gh")
    print("     scripts (runner.py + wake-rules.yaml, agent-run.sh, pm-gh.sh, workitems.py,")
    print("     blockers.py, spend_log.py, decisions.py, last-ship.sh, github-pm-setup.sh, the")
    print("     .claude/skills) live in the reference org repo that runs the live Scrum Jail")
    print("     org (private) — copy them into scripts/ here, or build to their contracts.")
    print("     Also seed decisions.yaml, .github/CODEOWNERS (route /decisions.yaml to the")
    print("     Chairman), and .github/ISSUE_TEMPLATE from the reference repo.")
    print("  2. Create the org repo on GitHub and push this directory; `gh auth login`,")
    print("     then `gh auth refresh -s project`. `cp .env.example .env` and fill it in.")
    print("  3. Chairman Settings — the two human-only steps no agent can perform:")
    print("     a) product repo → Settings → Environments → new environment `production`,")
    print("        required reviewer = you (this IS the 🚀 deploy gate);")
    print("     b) org repo → Settings → Branches → protect main: require a PR + require")
    print("        Code Owner review (this makes the decisions.yaml merge gate binding).")
    print("  4. Run scripts/github-pm-setup.sh — dept:* labels + the org Project with the")
    print("     Stage field from org-chart.yaml pm_stages.")
    print("  5. File the first [OBJECTIVE] issue (labeled dept:ceo) to inject work, then run")
    print("     the runner in RUNNER_MODE=shadow; flip to live once the logged would-be")
    print("     wakes look right.")
    print("  6. Customize agents/{ceo,business,it}.md — especially the CEO (objectives,")
    print("     reviews, PI cadence per safe.md). The stamped files are skeletons.")
    print("  7. Read blocker-ledger.md + safe.md before week 2.")


def org_readme(org, product, depts):
    rows = "\n".join(f"| {n} | {r} | `dept:{n}` |" for n, r, _ in depts)
    return f"""# {org} — autonomous org

A governance-gated multi-agent org for **{product}**, stamped from the
[scrum-jail-governance-playbook](https://github.com/johnplantada/scrum-jail-governance-playbook).

GitHub-native: work is Issues + one Project, wakes route on `dept:*` labels, and agents
propose while **the Chairman's merge/approval is the authorization** — enforced by the
platform (the product repo's `production` environment, CODEOWNERS + branch protection on
`decisions.yaml`). See `DESIGN.md` for the constitution and `org-chart.yaml` for the
tree + envelopes.

## Departments

| Agent | Role | Wake label |
|---|---|---|
{rows}

## Governance & operability docs
- `DESIGN.md` — the one-page constitution (the five invariants)
- `org-chart.yaml` — who exists, envelopes, cadences, model tiers
- `blockers.yaml` — the EV-ordered human-task ledger (the Chairman's queue)
- plus the playbook docs copied alongside (patterns, SAFe cadence, blocker ledger,
  field notes, RUNBOOK)

## Setup
1. Bring the runtime scripts (runner/pm-gh/agent-run + skills) from the reference org
   repo — orggen stamps the governance layer only; see RUNBOOK.md.
2. `gh auth login` + `gh auth refresh -s project`; `cp .env.example .env` and fill it in.
3. Chairman Settings: the product repo's `production` environment (required reviewer =
   you) and branch protection + CODEOWNERS review on this repo's `main`.
4. `scripts/github-pm-setup.sh` → file the first `[OBJECTIVE]` issue →
   `RUNNER_MODE=shadow`, then live.
"""


def main():
    p = argparse.ArgumentParser(prog="orggen", description="Stamp a governance-gated agent org.")
    sub = p.add_subparsers(dest="cmd", required=True)
    pi = sub.add_parser("init", help="stamp a new org skeleton into <target-dir>")
    pi.add_argument("target", help="directory to create the new org in")
    pi.add_argument("--org", help="org name (default: target dir name); also the org repo name")
    pi.add_argument("--product", help="the product the org runs (default: org name)")
    pi.add_argument("--goal", help="the org's north-star goal, e.g. '$10k/month' (default: placeholder)")
    pi.add_argument("--chairman-github", help="your GitHub username — the decision authority "
                                              "(CODEOWNERS + production environment; default: leave placeholder)")
    pi.add_argument("--product-repo", help="owner/repo of the product repo agents PR into "
                                           "(default: <chairman>/<product-repo> placeholder)")
    pi.add_argument("--departments", help="comma names; ceo always included (default: ceo,business,it)")
    pi.set_defaults(func=cmd_init)
    args = p.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
